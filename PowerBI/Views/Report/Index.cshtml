@model List<PowerBI.Models.Report>

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="fw-bold mb-1">Reports in @ViewBag.WorkspaceName</h2>
        <p class="text-muted small">
            <i class="bi bi-arrow-repeat text-primary animate-spin me-1"></i> 
            Synced with Power BI Service
        </p>
    </div>
    <button class="btn btn-primary shadow-sm" data-bs-toggle="modal" data-bs-target="#uploadReportModal">
        <i class="bi bi-upload me-2"></i> Upload Report
    </button>
</div>

@if (ViewBag.SyncError != null)
{
    <div class="alert alert-warning glass-card border-0 mb-4">
        <i class="bi bi-cloud-slash me-2"></i> @ViewBag.SyncError
    </div>
}

<div class="glass-card border-0 animate-fade-in">
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead>
                <tr class="text-muted small uppercase">
                    <th class="border-0 ps-4">Report Name</th>
                    <th class="border-0">Type</th>
                    <th class="border-0">Power BI ID</th>
                    <th class="border-0 text-end pe-4">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="4" class="text-center py-5 text-muted">
                            <i class="bi bi-folder-x fs-2 d-block mb-2"></i>
                            No reports found in this workspace.
                        </td>
                    </tr>
                }
                @foreach (var r in Model)
                {
                    <tr class="align-middle">
                        <td class="ps-4">
                            <div class="d-flex align-items-center">
                                <div class="bg-primary bg-opacity-10 p-2 rounded me-3">
                                    <i class="bi bi-file-bar-graph text-primary"></i>
                                </div>
                                <span class="fw-bold">@r.Name</span>
                            </div>
                        </td>
                        <td>
                            @if(r.ReportType == "RDL") {
                                <span class="badge bg-warning bg-opacity-10 text-warning px-3">Paginated</span>
                            } else {
                                <span class="badge bg-info bg-opacity-10 text-info px-3">Power BI</span>
                            }
                        </td>
                        <td class="text-muted small">
                            <code>@(r.PowerBIReportId?.Length > 12 ? r.PowerBIReportId.Substring(0, 12) + "..." : r.PowerBIReportId)</code>
                        </td>
                        <td class="text-end pe-4">
                            <div class="btn-group">
                                <a asp-action="Preview" asp-route-reportId="@r.Id" class="btn btn-outline-primary btn-sm px-3">
                                    <i class="bi bi-eye me-1"></i> Preview
                                </a>
                                <a asp-action="Export" asp-route-reportId="@r.Id" class="btn btn-outline-secondary btn-sm px-3 ms-2">
                                    <i class="bi bi-file-earmark-pdf me-1"></i> PDF
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- Modal -->
<div class="modal fade" id="uploadReportModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content glass-card border-0">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold">Upload New Report</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form method="post" enctype="multipart/form-data" asp-action="Upload">
                <input type="hidden" name="workspaceId" value="@ViewBag.WorkspaceId" />
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label text-muted small">Select .pbix or .rdl file</label>
                        <input type="file" name="file" class="form-control bg-light border-light" required />
                    </div>
                    <div class="bg-light p-3 rounded-3 mb-3 border border-dashed">
                        <p class="small fw-bold mb-2">Don't have a report? Download samples:</p>
                        <div class="d-flex gap-2">
                            <a href="/Dummy_RDL.rdl" download class="btn btn-sm btn-outline-dark">
                                <i class="bi bi-download me-1"></i> Dummy RDL
                            </a>
                            <a href="https://github.com/microsoft/powerbi-desktop-samples/raw/main/Monthly%20Sales%20and%20Profit%20Sample.pbix" target="_blank" class="btn btn-sm btn-outline-dark">
                                <i class="bi bi-file-earmark-bar-graph me-1"></i> Sample PBIX
                            </a>
                        </div>
                        <p class="text-muted extra-small mt-2 mb-0">Note: RDL reports require Premium capacity when using Service Principal.</p>
                    </div>
                    <p class="text-info small"><i class="bi bi-info-circle me-1"></i> This file will be uploaded directly to the Power BI Service.</p>
                </div>
                <div class="modal-footer border-0 pt-0">
                    <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary px-4">Start Import</button>
                </div>
            </form>
        </div>
    </div>
</div>

<style>
    .animate-spin {
        animation: spin 2s linear infinite;
        display: inline-block;
    }
    @@keyframes spin {
        100% { transform: rotate(360deg); }
    }
    .uppercase { text-transform: uppercase; letter-spacing: 0.05em; }
    .extra-small { font-size: 0.7rem; }
</style>