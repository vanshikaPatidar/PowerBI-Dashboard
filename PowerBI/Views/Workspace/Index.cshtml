@model IEnumerable<PowerBI.Models.Workspace>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h2 fw-bold mb-1">My Workspaces</h1>
            <p class="text-muted small">
                <i class="bi bi-arrow-repeat text-primary animate-spin me-1"></i> 
                Synced with Power BI Service
            </p>
        </div>
        <div class="d-flex gap-2">
            <a asp-action="Index" class="btn btn-outline-primary shadow-sm">
                <i class="bi bi-arrow-repeat me-2"></i> Sync with Service
            </a>
            <button class="btn btn-primary shadow-sm" data-bs-toggle="modal" data-bs-target="#createWorkspaceModal">
                <i class="bi bi-plus-lg me-2"></i> New Workspace
            </button>
        </div>
    </div>

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger glass-card border-0 mb-4">
            <i class="bi bi-exclamation-triangle me-2"></i> @TempData["Error"]
        </div>
    }

    @if (ViewBag.SyncError != null)
    {
        <div class="alert alert-warning glass-card border-0 mb-4">
            <i class="bi bi-cloud-slash me-2"></i> @ViewBag.SyncError
        </div>
    }

    <div class="row g-4">
        @foreach (var ws in Model)
        {
            <div class="col-md-4 col-xl-3">
                <div class="glass-card h-100 animate-fade-in border-0 position-relative">
                    <div class="dropdown position-absolute top-0 end-0 p-2">
                        <button class="btn btn-link text-muted p-1" data-bs-toggle="dropdown">
                            <i class="bi bi-three-dots-vertical"></i>
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end glass-card border-0 shadow">
                            <li>
                                <button class="dropdown-item small py-2" onclick="openRenameModal(@ws.Id, '@ws.Name')">
                                    <i class="bi bi-pencil me-2"></i> Rename
                                </button>
                            </li>
                            <li><hr class="dropdown-divider bg-secondary"></li>
                            <li>
                                <form asp-action="Delete" asp-route-id="@ws.Id" method="post" onsubmit="return confirm('Are you sure you want to delete this workspace from both App and Power BI Service?')">
                                    <button type="submit" class="dropdown-item small py-2 text-danger">
                                        <i class="bi bi-trash me-2"></i> Delete
                                    </button>
                                </form>
                            </li>
                        </ul>
                    </div>

                    <div class="d-flex align-items-start justify-content-between mb-3">
                        <div class="bg-primary bg-opacity-10 p-3 rounded-3">
                            <i class="bi bi-folder2-open fs-3 text-primary"></i>
                        </div>
                        <span class="badge bg-success bg-opacity-10 text-success small">Synced</span>
                    </div>
                    <h5 class="fw-bold mb-2">@ws.Name</h5>
                    <p class="text-muted small mb-4">ID: @(ws.PowerBIWorkspaceId?.Length > 8 ? ws.PowerBIWorkspaceId.Substring(0, 8) : ws.PowerBIWorkspaceId)...</p>
                    <a asp-controller="Report" asp-action="Index" asp-route-workspaceId="@ws.Id" class="btn btn-outline-primary w-100 btn-sm">
                        Open Workspace
                    </a>
                </div>
            </div>
        }
    </div>
</div>

<!-- Create Workspace Modal -->
<div class="modal fade" id="createWorkspaceModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content glass-card border-0">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold">Create Workspace</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="Create" method="post">
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label text-muted small">Workspace Name</label>
                        <input type="text" name="name" class="form-control bg-light border-light" placeholder="Enter name..." required>
                    </div>
                    <p class="text-info small"><i class="bi bi-info-circle me-1"></i> If the name exists in Power BI, it will be linked instead of created.</p>
                </div>
                <div class="modal-footer border-0 pt-0">
                    <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary px-4">Create or Link</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Rename Workspace Modal -->
<div class="modal fade" id="renameWorkspaceModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content glass-card border-0">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold">Rename Workspace</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="Rename" method="post">
                <input type="hidden" name="id" id="renameWsId">
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label text-muted small">New Workspace Name</label>
                        <input type="text" name="newName" id="renameWsName" class="form-control bg-light border-light" required>
                    </div>
                    <p class="text-warning small"><i class="bi bi-exclamation-circle me-1"></i> This will rename the workspace in Power BI Service too.</p>
                </div>
                <div class="modal-footer border-0 pt-0">
                    <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary px-4">Save Changes</button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
    function openRenameModal(id, name) {
        document.getElementById('renameWsId').value = id;
        document.getElementById('renameWsName').value = name;
        new bootstrap.Modal(document.getElementById('renameWorkspaceModal')).show();
    }
</script>

<style>
    .animate-spin {
        animation: spin 2s linear infinite;
        display: inline-block;
    }
    @@keyframes spin {
        100% { transform: rotate(360deg); }
    }
</style>