
## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# User-specific files (MonoDevelop/Xamarin Studio)
*.userprefs

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/

# Visual Studio 2015/2017 cache/options directory
.vs/
# Uncomment if you use Visual Studio Code
#.vscode/

# MSTest test Results
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*

# NUNIT
*.VisualState.xml
TestResult.xml

# Build log of MSBuild
*.unexpected

# Visual Studio Profiler
*.psess
*.vsp
*.vspx
*.sap

# Visual Studio Server Explorer config
Backup*/

# Node.js / NPM
node_modules/
npm-debug.log

# Entity Framework 6+ (e.g. EF Core)
*.db
*.db-shm
*.db-wal

# Others
appsettings.json
appsettings.Development.json
appsettings.Production.json
appsettings.*.json
*.csproj.user
